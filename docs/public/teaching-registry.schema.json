{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://longbiaochen.github.io/heuristic-learning/teaching-registry.schema.json",
  "title": "Heuristic Learning Teaching Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "materials"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/material"
      }
    }
  },
  "$defs": {
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "path",
        "route",
        "core_question",
        "reading",
        "commands",
        "deliverable"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(lecture|lab)-[0-9]+$"
        },
        "type": {
          "type": "string",
          "enum": ["lecture", "lab"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "pattern": "^docs/zh-cn/slides/.+/index\\.md$"
        },
        "route": {
          "type": "string",
          "pattern": "^/zh-cn/slides/.+/$"
        },
        "core_question": {
          "type": "string",
          "minLength": 1
        },
        "reading": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^docs/zh-cn/.+\\.md$"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^npm run .+"
          }
        },
        "deliverable": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
