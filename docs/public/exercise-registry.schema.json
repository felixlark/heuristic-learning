{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Exercise Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exercise_sets"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "exercise_sets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/exercise_set"
      }
    }
  },
  "$defs": {
    "exercise_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "difficulty",
        "learning_unit_ids",
        "rubric_module_ids",
        "exercises"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string"
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "concept",
            "code",
            "experiment",
            "capstone"
          ]
        },
        "learning_unit_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "rubric_module_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "exercises": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/exercise"
          }
        }
      }
    },
    "exercise": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "prompt",
        "input_paths",
        "example_ids",
        "deliverable",
        "verification_commands",
        "acceptance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-D][0-9]+$"
        },
        "title": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "input_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "example_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deliverable": {
          "type": "string"
        },
        "verification_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "acceptance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
