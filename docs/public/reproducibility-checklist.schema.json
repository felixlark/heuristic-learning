{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Reproducibility Checklist",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checklists"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "checklists": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/checklist"
      }
    }
  },
  "$defs": {
    "checklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "scope",
        "evidence",
        "commands",
        "pass_condition",
        "known_boundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "pass_condition": {
          "type": "string"
        },
        "known_boundary": {
          "type": "string"
        }
      }
    }
  }
}
