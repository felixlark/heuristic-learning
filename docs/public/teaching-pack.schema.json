{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://longbiaochen.github.io/heuristic-learning/teaching-pack.schema.json",
  "title": "Heuristic Learning Teaching Pack Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "packs"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "packs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pack"
      }
    }
  },
  "$defs": {
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "duration",
        "audience",
        "slides",
        "readings",
        "demo_commands",
        "deliverable",
        "acceptance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^tp[0-9]-[a-z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "duration": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        },
        "slides": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^docs/zh-cn/slides/.+\\.md$"
          }
        },
        "readings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^docs/zh-cn/.+\\.md$"
          }
        },
        "demo_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^npm run .+"
          }
        },
        "deliverable": {
          "type": "string",
          "minLength": 1
        },
        "acceptance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
