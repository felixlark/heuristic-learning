{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Completion Audit Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "objective",
    "requirements",
    "required_commands",
    "evidence_boundaries",
    "final_checks"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "required_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/boundary"
      }
    },
    "final_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "evidence",
        "verification"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "topic",
        "boundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "topic": {
          "type": "string"
        },
        "boundary": {
          "type": "string"
        }
      }
    }
  }
}
