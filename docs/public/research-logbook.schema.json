{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Research Logbook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "source_type",
        "source_ref",
        "reading_goal",
        "bound_examples",
        "bound_claims",
        "metrics",
        "commands",
        "deliverables",
        "next_action",
        "boundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "status": {
          "type": "string",
          "enum": [
            "seeded",
            "active",
            "needs-source-refresh"
          ]
        },
        "source_type": {
          "type": "string",
          "enum": [
            "public-essay",
            "public-code-artifact",
            "x-source",
            "sanitized-application",
            "cross-example-analysis"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "reading_goal": {
          "type": "string",
          "minLength": 1
        },
        "bound_examples": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "bound_claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^npm run .+"
          }
        },
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        },
        "boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
