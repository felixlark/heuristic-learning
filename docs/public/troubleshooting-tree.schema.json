{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Troubleshooting Tree",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scope",
    "nodes"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "scope": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "failure_surface",
        "symptom",
        "diagnostic_commands",
        "likely_causes",
        "fix_actions",
        "verification_commands",
        "related_pages"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "failure_surface": {
          "type": "string"
        },
        "symptom": {
          "type": "string"
        },
        "diagnostic_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "likely_causes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "fix_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "verification_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "related_pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
