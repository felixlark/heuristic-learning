{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Slide Deck Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "materials"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/material"
      }
    }
  },
  "$defs": {
    "material": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "route",
        "format",
        "required_headings",
        "example_ids",
        "commands",
        "deliverable_template"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(lecture|lab)-[0-9]+$"
        },
        "path": {
          "type": "string"
        },
        "route": {
          "type": "string"
        },
        "format": {
          "enum": [
            "lecture",
            "lab"
          ]
        },
        "required_headings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "example_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "deliverable_template": {
          "type": "string"
        }
      }
    }
  }
}
