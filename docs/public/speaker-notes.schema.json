{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Speaker Notes Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "notes"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/note"
      }
    }
  },
  "$defs": {
    "note": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "material_id",
        "title",
        "slide_path",
        "opening_question",
        "demo_checkpoints",
        "discussion_prompts",
        "common_confusions",
        "exit_ticket",
        "verification_commands"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^note-(lecture|lab)-[0-9]+$"
        },
        "material_id": {
          "type": "string",
          "pattern": "^(lecture|lab)-[0-9]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "slide_path": {
          "type": "string",
          "pattern": "^docs/zh-cn/slides/.+/index\\.md$"
        },
        "opening_question": {
          "type": "string",
          "minLength": 1
        },
        "demo_checkpoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "discussion_prompts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "common_confusions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exit_ticket": {
          "type": "string",
          "minLength": 1
        },
        "verification_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^npm run .+"
          }
        }
      }
    }
  }
}
