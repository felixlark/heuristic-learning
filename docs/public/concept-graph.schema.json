{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Concept Graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "concepts"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/concept"
      }
    }
  },
  "$defs": {
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "term",
        "definition",
        "claim_ids",
        "example_ids",
        "material_ids",
        "pages",
        "commands"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "term": {
          "type": "string",
          "minLength": 1
        },
        "definition": {
          "type": "string",
          "minLength": 1
        },
        "claim_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "example_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "material_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "pages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^docs/.+"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^npm run .+"
          }
        }
      }
    }
  }
}
