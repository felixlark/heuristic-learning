        "docs/public/x-sources.json",
        "templates/case-card.md"
      ],
      "assessment": "读者能保留来源层级，不把未复核线索写成已复现事实。",
      "verification_commands": [
        "npm run source:registry:check",
        "npm run x:sources:check"
      ]
    },
    {
      "id": "lo-4",
      "title": "设计可维护 heuristic patch",
      "competency": "能把一次规则更新限定在可审查目标，并用测试或 replay 防止退化。",
      "learning_unit_ids": [
        "u3-control-and-systems",
