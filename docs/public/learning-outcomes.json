        "docs/zh-cn/theory/learning-loop.md",
        "templates/anti-forgetting-checklist.md",
        "tests/"
      ],
      "assessment": "读者能说明旧行为、风险更新、回归保护和必须保留的 probe。",
      "verification_commands": [
        "npm run examples:test",
        "npm run examples:feedback"
      ]
    },
    {
      "id": "lo-5",
