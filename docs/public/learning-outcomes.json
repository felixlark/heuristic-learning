{
  "$schema": "/learning-outcomes.schema.json",
  "schema_version": 1,
  "outcomes": [
    {
      "id": "lo-1",
      "title": "解释 HL 问题边界",
      "competency": "能区分 Heuristic System、Heuristic Learning、RL/DL 分工和研究假设边界。",
      "learning_unit_ids": [
        "u0-context",
        "u4-research-claims"
      ],
      "exercise_ids": [
        "A1",
        "A2",
        "A3"
      ],
      "rubric_module_ids": [
        "source-and-problem"
      ],
      "evidence": [
        "docs/zh-cn/stage-2/index.md",
        "docs/zh-cn/stage-3/index.md",
        "docs/zh-cn/theory/research-framework.md"
      ],
      "assessment": "读者能用一个案例说明反馈来源、更新对象、验证方式和未验证边界。",
      "verification_commands": [
        "npm run claims:registry:check"
      ]
    },
    {
      "id": "lo-2",
      "title": "运行并解释最小闭环",
      "competency": "能跑通示例、读懂 baseline failure、heuristic outcome 和 feedback report。",
      "learning_unit_ids": [
        "u1-minimal-loop"
      ],
      "exercise_ids": [
        "B1",
        "C3"
      ],
      "rubric_module_ids": [
        "probe-and-baseline",
        "feedback-report"
      ],
      "evidence": [
        "docs/zh-cn/examples/index.md",
        "examples/heuristic-gridworld/README.md",
        "experiments/gridworld/latest.json"
      ],
      "assessment": "读者能指出 failure mode、candidate_update.target 和 verification command。",
      "verification_commands": [
        "npm run examples:gridworld:feedback",
        "npm run examples:reports:check"
      ]
    },
    {
      "id": "lo-3",
      "title": "把来源转成案例证据",
      "competency": "能把公开 artifact、X 来源或脱敏应用问题整理成来源状态、case card 和验证计划。",
      "learning_unit_ids": [
        "u2-public-artifacts",
        "u3-control-and-systems"
      ],
      "exercise_ids": [
        "A4",
        "D1",
        "D3"
