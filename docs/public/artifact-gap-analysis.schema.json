{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Artifact Gap Analysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scope",
    "artifacts"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "scope": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "source_status",
        "source_reference",
        "example_id",
        "current_replay",
        "missing_fidelity",
        "next_experiment",
        "verification_commands",
        "boundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string"
        },
        "source_status": {
          "type": "string"
        },
        "source_reference": {
          "type": "string"
        },
        "example_id": {
          "type": "string"
        },
        "current_replay": {
          "type": "string"
        },
        "missing_fidelity": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "next_experiment": {
          "type": "string"
        },
        "verification_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "boundary": {
          "type": "string"
        }
      }
    }
  }
}
