{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Rubric Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "title",
    "passing_score",
    "minimum_mainline_score",
    "modules",
    "deliverables",
    "verification_commands"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "title": {
      "type": "string"
    },
    "passing_score": {
      "type": "integer",
      "minimum": 1
    },
    "minimum_mainline_score": {
      "type": "integer",
      "minimum": 1
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/module"
      }
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "verification_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "weight",
        "minimum_standard",
        "evidence",
        "score_levels"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string"
        },
        "weight": {
          "type": "integer",
          "minimum": 1
        },
        "minimum_standard": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "score_levels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/score_level"
          }
        }
      }
    },
    "score_level": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "criterion"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0
        },
        "criterion": {
          "type": "string"
        }
      }
    }
  }
}
