{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://felixlark.github.io/heuristic-learning/learning-units.schema.json",
  "title": "Heuristic Learning Units Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "units"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/unit"
      }
    }
  },
  "$defs": {
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "core_question",
        "readings",
        "examples",
        "commands",
        "deliverable",
        "acceptance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^u[0-9]-[a-z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "core_question": {
          "type": "string",
          "minLength": 1
        },
        "readings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^docs/zh-cn/.+\\.md$"
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^npm run .+"
          }
        },
        "deliverable": {
          "type": "string",
          "minLength": 1
        },
        "acceptance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
