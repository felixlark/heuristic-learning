{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://longbiaochen.github.io/heuristic-learning/course-patterns.schema.json",
  "title": "Heuristic Learning Course Patterns Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "patterns"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pattern"
      }
    }
  },
  "$defs": {
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "reference",
        "borrowed_pattern",
        "repo_evidence",
        "verification",
        "boundary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "reference": {
          "type": "string",
          "minLength": 1
        },
        "borrowed_pattern": {
          "type": "string",
          "minLength": 1
        },
        "repo_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^npm run .+"
          }
        },
        "boundary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
