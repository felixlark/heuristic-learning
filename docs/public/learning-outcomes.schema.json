{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Heuristic Learning Outcomes Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "outcomes"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/outcome"
      }
    }
  },
  "$defs": {
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "competency",
        "learning_unit_ids",
        "exercise_ids",
        "rubric_module_ids",
        "evidence",
        "assessment",
        "verification_commands"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^lo-[0-9]+$"
        },
        "title": {
          "type": "string"
        },
        "competency": {
          "type": "string"
        },
        "learning_unit_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "exercise_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "rubric_module_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "assessment": {
          "type": "string"
        },
        "verification_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
