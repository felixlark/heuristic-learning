{
  "name": "heuristic-learning",
  "version": "0.1.0",
  "description": "直觉学习 Heuristic Learning 中文研究与动手课程",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/with-local-node.sh vitepress dev docs",
    "build": "npm run sitemap && bash scripts/with-local-node.sh node scripts/build.mjs",
    "build:force": "npm run sitemap && bash scripts/with-local-node.sh node scripts/build.mjs --force",
    "preview": "bash scripts/with-local-node.sh vitepress preview docs",
    "verify": "bash scripts/verify.sh",
    "lint": "eslint docs/.vitepress/theme",
    "lint:fix": "eslint docs/.vitepress/theme --fix",
    "sitemap": "bash scripts/with-local-node.sh node scripts/generate-sitemap.mjs",
    "docs:routes:check": "bash scripts/check-routes.sh",
    "examples:test": "python3 -m unittest discover -s tests",
    "examples:feedback": "npm run examples:gridworld:feedback && npm run examples:robot-soccer:feedback && npm run examples:vizdoom-replay:feedback && npm run examples:traffic-grid:feedback && npm run examples:breakout-replay:feedback && npm run examples:ant-gait-replay:feedback",
    "examples:reports:check": "python3 scripts/check-experiment-reports.py",
    "examples:registry:check": "python3 scripts/check-example-registry.py",
    "code:tour:check": "python3 scripts/check-code-tour.py",
    "benchmark:summary:check": "python3 scripts/check-benchmark-summary.py",
    "ablation:plan:check": "python3 scripts/check-ablation-plan.py",
    "artifact:gap:check": "python3 scripts/check-artifact-gap-analysis.py",
    "source:registry:check": "python3 scripts/check-source-registry.py",
    "cases:check": "python3 scripts/check-case-registry.py",
    "x:sources:check": "python3 scripts/check-x-sources.py",
    "source:case:check": "python3 scripts/check-source-to-case-playbook.py",
    "claims:registry:check": "python3 scripts/check-claims-registry.py",
    "teaching:registry:check": "python3 scripts/check-teaching-registry.py",
    "slides:check": "python3 scripts/check-slide-deck.py",
    "speaker:notes:check": "python3 scripts/check-speaker-notes.py",
    "rubric:check": "python3 scripts/check-rubric.py",
    "exercises:check": "python3 scripts/check-exercise-registry.py",
    "contribution:contract:check": "python3 scripts/check-contribution-contract.py",
    "reproducibility:check": "python3 scripts/check-reproducibility.py",
    "troubleshooting:tree:check": "python3 scripts/check-troubleshooting-tree.py",
    "patterns:check": "python3 scripts/check-course-patterns.py",
    "concept:graph:check": "python3 scripts/check-concept-graph.py",
    "learning:units:check": "python3 scripts/check-learning-units.py",
    "learning:outcomes:check": "python3 scripts/check-learning-outcomes.py",
    "checkpoints:check": "python3 scripts/check-checkpoints.py",
    "metrics:check": "python3 scripts/check-evaluation-metrics.py",
    "paper:blueprint:check": "python3 scripts/check-paper-blueprint.py",
    "teaching:pack:check": "python3 scripts/check-teaching-pack.py",
    "research:projects:check": "python3 scripts/check-research-projects.py",
    "research:logbook:check": "python3 scripts/check-research-logbook.py",
    "visual:verification:check": "python3 scripts/check-visual-verification.py",
    "completion:audit:check": "python3 scripts/check-completion-audit.py",
    "release:readiness:check": "python3 scripts/check-release-readiness.py",
    "course:manifest:check": "python3 scripts/check-course-manifest.py",
    "course:structure:check": "python3 scripts/check-course-structure.py",
    "examples:gridworld": "python3 examples/heuristic-gridworld/run.py --episodes 20",
    "examples:gridworld:feedback": "python3 examples/heuristic-gridworld/feedback_loop.py --out experiments/gridworld/latest.json",
    "examples:robot-soccer": "python3 examples/robot-soccer/run.py",
    "examples:robot-soccer:feedback": "python3 examples/robot-soccer/feedback_loop.py --out experiments/robot-soccer/latest.json",
    "examples:vizdoom-replay": "python3 examples/vizdoom-replay/run.py",
    "examples:vizdoom-replay:feedback": "python3 examples/vizdoom-replay/feedback_loop.py --out experiments/vizdoom-replay/latest.json",
    "examples:traffic-grid": "python3 examples/traffic-grid/run.py",
    "examples:traffic-grid:feedback": "python3 examples/traffic-grid/feedback_loop.py --out experiments/traffic-grid/latest.json",
    "examples:breakout-replay": "python3 examples/breakout-replay/run.py",
    "examples:breakout-replay:feedback": "python3 examples/breakout-replay/feedback_loop.py --out experiments/breakout-replay/latest.json",
    "examples:ant-gait-replay": "python3 examples/ant-gait-replay/run.py",
    "examples:ant-gait-replay:feedback": "python3 examples/ant-gait-replay/feedback_loop.py --out experiments/ant-gait-replay/latest.json"
  },
  "keywords": [
    "heuristic-learning",
    "research",
    "course",
    "vitepress",
    "agent"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "CC-BY-NC-SA-4.0",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.30.0",
    "markdown-it-katex": "^2.0.3",
    "prettier": "^3.7.4",
    "vue-eslint-parser": "^9.4.3"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "^2.13.1",
    "mermaid": "^11.13.0",
    "reveal.js": "^6.0.1",
    "typeit": "^8.8.7",
    "viewerjs": "^1.11.7",
    "vitepress": "^2.0.0-alpha.16",
    "vue": "^3.5.0"
  }
}
